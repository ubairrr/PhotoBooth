<screen>
    <view style_bg_color="0xFFE4E1" width="100%" height="100%">
        <!-- Header -->
        <lv_obj width="100%" height="42" style_bg_color="0xFFFFFF" style_bg_opa="200" flex_flow="row" style_flex_align_main="space_between" style_flex_align_cross="center">
            <lv_button id="btn_gallery" width="34" height="34" style_bg_color="0xFFB6C1" style_radius="8">
                <lv_label text="G" align="center" style_text_color="0xFFFFFF" />
            </lv_button>
            <lv_label text="PhotoBooth" style_text_color="0xFF69B4" />
            <lv_button id="btn_settings" width="34" height="34" style_bg_color="0xFFB6C1" style_radius="8">
                <lv_label text="S" align="center" style_text_color="0xFFFFFF" />
            </lv_button>
        </lv_obj>

        <!-- Viewfinder Box -->
        <lv_obj id="viewfinder" width="220" height="180" align="center" style_bg_color="0x000000" style_border_width="2" style_border_color="0xFF69B4" style_radius="10" />

        <!-- Capture Button -->
        <lv_button id="btn_capture" width="60" height="60" align="bottom_mid" style_bg_color="0xFFFFFF" style_border_width="3" style_border_color="0xFF69B4" style_radius="30">
            <lv_image src="images/flower_small.png" align="center" />
        </lv_button>
    </view>
</screen>