<component>
    <view>
        <!-- Root screen -->
        <lv_obj id="root" width="240" height="320" bg_color="#FFE4E1">
            
            <!-- Camera Area -->
            <lv_obj id="camera_container" width="100%" height="100%" bg_opa="0" border_width="0">
                <lv_canvas id="canvas" width="100%" height="100%" bg_color="#000000" />
                <lv_obj id="focus_frame" width="180" height="200" align="center" border_width="2" border_color="#FFFFFF" bg_opa="0" radius="10" />
                <lv_label id="timer_label" align="top_right" x="-12" y="12" text="" />
                <lv_label id="countdown_label" align="center" y="-20" text="" text_color="#FF69B4" hidden="true" />
            </lv_obj>

            <!-- Top Bar -->
            <lv_obj id="top_bar" width="100%" height="40" align="top_mid" bg_color="#FFFFFF" bg_opa="200" flex_flow="row" flex_main_place="space_between" flex_cross_place="center">
                <lv_label text="Maryam's Booth" />
                <lv_btn id="btn_gallery" width="32" height="32" bg_color="#FFB6C1">
                    <lv_label text="G" align="center" />
                </lv_btn>
                <lv_img src="images/cat_peek.png" />
                <lv_img src="images/bow_small.png" />
            </lv_obj>

            <!-- Bottom Bar -->
            <lv_obj id="bottom_bar" width="100%" height="68" align="bottom_mid" bg_color="#FFFFFF" flex_flow="row" flex_main_place="space_around" flex_cross_place="center">
                <lv_btn id="btn_filters" width="58" height="38" bg_color="#FFB6C1">
                    <lv_label text="FX" align="center" />
                </lv_btn>

                <!-- Capture Button -->
                <lv_btn id="btn_capture" width="56" height="56" radius="circle" bg_color="#FFFFFF" border_width="2" border_color="#FF69B4">
                    <lv_obj id="capture_core" width="30" height="30" align="center" radius="circle" bg_color="#FF69B4">
                        <lv_img src="images/flower_small.png" align="center" />
                    </lv_obj>
                </lv_btn>

                <lv_btn id="btn_settings" width="58" height="38" bg_color="#FFB6C1">
                    <lv_label text="S" align="center" />
                </lv_btn>

                <lv_img src="images/cat_idle.png" />
                <lv_img src="images/cat_happy.png" />
            </lv_obj>
        </lv_obj>
    </view>
</component>
