<component>
    <view>
        <!-- Root screen -->
        <lv_obj id="root" width="240" height="320" style_bg_color="0xFFE4E1">
            
            <!-- Camera Area -->
            <lv_obj id="camera_container" width="100p" height="100p" style_bg_opa="0" style_border_width="0">
                <lv_canvas id="canvas" width="100p" height="100p" style_bg_color="0x000000" />
                <lv_obj id="focus_frame" width="180" height="200" align="center" style_border_width="2" style_border_color="0xFFFFFF" style_bg_opa="0" style_radius="10" />
                <lv_label id="timer_label" align="top_right" x="-12" y="12" text="" />
                <lv_label id="countdown_label" align="center" y="-20" text="" style_text_color="0xFF69B4" hidden="true" />
            </lv_obj>

            <!-- Top Bar -->
            <lv_obj id="top_bar" width="100p" height="40" align="top_mid" style_bg_color="0xFFFFFF" style_bg_opa="200" flex_flow="row" flex_align_main="space_between" flex_align_cross="center">
                <lv_label text="Maryam's Booth" />
                <lv_button id="btn_gallery" width="32" height="32" style_bg_color="0xFFB6C1">
                    <lv_label text="G" align="center" />
                </lv_button>
                <lv_image src="images/cat_peek.png" />
                <lv_image src="images/bow_small.png" />
            </lv_obj>

            <!-- Bottom Bar -->
            <lv_obj id="bottom_bar" width="100p" height="68" align="bottom_mid" style_bg_color="0xFFFFFF" flex_flow="row" flex_align_main="space_around" flex_align_cross="center">
                <lv_button id="btn_filters" width="58" height="38" style_bg_color="0xFFB6C1">
                    <lv_label text="FX" align="center" />
                </lv_button>

                <!-- Capture Button -->
                <lv_button id="btn_capture" width="56" height="56" style_radius="circle" style_bg_color="0xFFFFFF" style_border_width="2" style_border_color="0xFF69B4">
                    <lv_obj id="capture_core" width="30" height="30" align="center" style_radius="circle" style_bg_color="0xFF69B4">
                        <lv_image src="images/flower_small.png" align="center" />
                    </lv_obj>
                </lv_button>

                <lv_button id="btn_settings" width="58" height="38" style_bg_color="0xFFB6C1">
                    <lv_label text="S" align="center" />
                </lv_button>

                <lv_image src="images/cat_idle.png" />
                <lv_image src="images/cat_happy.png" />
            </lv_obj>
        </lv_obj>
    </view>
</component>
