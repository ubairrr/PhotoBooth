<component>
    <view>
        <lv_obj id="root" width="240" height="320" style_bg_color="0xFFE4E1">
            
            <!-- Shared Header -->
            <lv_obj id="header" width="100p" height="44" align="top_mid" style_bg_color="0xFFFFFF" style_bg_opa="200" flex_flow="row" flex_align_main="space_between" flex_align_cross="center" style_pad_left="10" style_pad_right="10">
                <lv_label text="Gallery" />
                <lv_button id="btn_share" width="60" height="36" style_bg_color="0xFF69B4">
                    <lv_label text="Share" align="center" />
                </lv_button>
                <lv_button id="btn_back_main" width="40" height="36" style_bg_color="0xFFB6C1">
                    <lv_label text="&lt;" align="center" />
                </lv_button>
            </lv_obj>

            <!-- Grid View -->
            <lv_obj id="grid_view" width="100p" height="236" y="44" style_bg_opa="0" flex_flow="row_wrap" style_pad_all="6" scroll_dir="y">
                <!-- Mock thumbnail cards -->
                <lv_obj width="80" height="106" style_bg_color="0xFFFFFF" style_border_width="1" style_border_color="0xFF69B4" style_radius="4">
                    <lv_image src="images/cat_idle.png" align="center" />
                </lv_obj>
                <lv_obj width="80" height="106" style_bg_color="0xFFFFFF" style_border_width="1" style_border_color="0xFF69B4" style_radius="4">
                    <lv_image src="images/cat_happy.png" align="center" />
                </lv_obj>
            </lv_obj>

            <!-- Grid Pagination Footer -->
            <lv_obj id="grid_footer" width="100p" height="40" align="bottom_mid" style_bg_color="0xFFFFFF" flex_flow="row" flex_align_main="space_around" flex_align_cross="center">
                <lv_button id="btn_prev" width="50" height="32" style_bg_color="0xFFB6C1">
                    <lv_label text="&lt;" align="center" />
                </lv_button>
                <lv_label id="page_label" text="1 / 1" />
                <lv_button id="btn_next" width="50" height="32" style_bg_color="0xFFB6C1">
                    <lv_label text="&gt;" align="center" />
                </lv_button>
            </lv_obj>

            <!-- Detail View (Hidden by default) -->
            <lv_obj id="detail_view" width="100p" height="100p" style_bg_color="0xFFE4E1" hidden="true">
                <lv_canvas id="detail_canvas" width="100p" height="100p" style_bg_color="0x000000" />
                <lv_label id="detail_status" text="" align="center" />

                <!-- Detail Footer -->
                <lv_obj id="detail_footer" width="100p" height="56" align="bottom_mid" style_bg_color="0xFFFFFF" flex_flow="row" flex_align_main="space_around" flex_align_cross="center">
                    <lv_button id="btn_detail_back" width="90" height="38" style_bg_color="0xFFB6C1">
                        <lv_label text="Back" align="center" />
                    </lv_button>
                    <lv_button id="btn_detail_del" width="90" height="38" style_bg_color="0xFF69B4">
                        <lv_label text="Delete" align="center" />
                    </lv_button>
                </lv_obj>
            </lv_obj>

        </lv_obj>
    </view>
</component>
