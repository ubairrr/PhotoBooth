<component>
    <view>
        <lv_obj id="root" width="240" height="320" style_bg_color="0xFFE4E1">
            <lv_canvas id="canvas" width="100p" height="100p" style_bg_color="0x000000" />
            
            <lv_obj id="top_bar" width="100p" height="40" align="top_mid" style_bg_color="0xFFFFFF" style_bg_opa="200">
                <lv_label text="Preview" align="center" />
            </lv_obj>

            <lv_label id="status_label" text="Waiting for capture..." align="center" />

            <lv_obj id="bottom_bar" width="100p" height="70" align="bottom_mid" style_bg_color="0xFFFFFF" flex_flow="row" flex_align_main="space_around" flex_align_cross="center">
                <lv_button id="btn_retake" width="82" height="40" style_bg_color="0xFFB6C1">
                    <lv_label text="Retake" align="center" />
                </lv_button>

                <lv_button id="btn_save" width="82" height="40" style_bg_color="0xFF69B4">
                    <lv_label text="Save" align="center" />
                </lv_button>
            </lv_obj>
        </lv_obj>
    </view>
</component>
