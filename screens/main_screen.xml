<screen>
    <view style_bg_color="0xFFE4E1" width="100%" height="100%" flex_flow="column" style_flex_main_place="space_between" style_flex_cross_place="center">
        <!-- Header -->
        <lv_obj width="100%" height="42" style_bg_color="0xFFFFFF" style_bg_opa="200" flex_flow="row" style_flex_main_place="space_between" style_flex_cross_place="center">
            <lv_button name="btn_gallery" width="34" height="34" style_bg_color="0xFFB6C1" style_radius="8">
                <lv_label text="G" align="center" style_text_color="0xFFFFFF" />
            </lv_button>
            <lv_label text="PhotoBooth" style_text_color="0xFF69B4" />
            <lv_button name="btn_settings" width="34" height="34" style_bg_color="0xFFB6C1" style_radius="8">
                <lv_label text="S" align="center" style_text_color="0xFFFFFF" />
            </lv_button>
        </lv_obj>

        <!-- Viewfinder Box -->
        <lv_obj name="viewfinder" width="220" height="180" style_bg_color="0x000000" style_border_width="2" style_border_color="0xFF69B4" style_radius="10" />

        <!-- Capture Button Wrapper -->
        <lv_obj width="100%" height="80" style_bg_opa="0" flex_flow="row" style_flex_main_place="center" style_flex_cross_place="center">
            <lv_button name="btn_capture" width="60" height="60" style_bg_color="0xFFFFFF" style_border_width="3" style_border_color="0xFF69B4" style_radius="30">
                <lv_image src="images/flower_small.png" />
            </lv_button>
        </lv_obj>
    </view>
</screen>