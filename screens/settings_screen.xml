<screen>
    <view style_bg_color="0xFFE4E1" width="100%" height="100%">
        <!-- Header -->
        <lv_obj width="100%" height="42" style_bg_color="0xFFFFFF" style_bg_opa="200" flex_flow="row" style_flex_main_place="space_between" style_flex_cross_place="center" style_pad_left="10" style_pad_right="10">
            <lv_label text="Settings" />
            <lv_button name="btn_back" width="34" height="34" style_bg_color="0xFFB6C1">
                <lv_label text="&lt;" align="center" />
            </lv_button>
        </lv_obj>

        <!-- Content -->
        <lv_obj width="100%" height="278" y="42" style_bg_opa="0" flex_flow="column" style_flex_cross_place="center" style_pad_all="10" style_pad_row="10">
            <lv_button width="220" height="44" style_bg_color="0xFFFFFF" style_radius="8" style_border_width="1" style_border_color="0xFF69B4">
                <lv_label text="Countdown" align="left_mid" x="10" />
                <lv_label text="Off" align="right_mid" x="-10" style_text_color="0xFF69B4" />
            </lv_button>

            <lv_button width="220" height="44" style_bg_color="0xFFFFFF" style_radius="8" style_border_width="1" style_border_color="0xFF69B4">
                <lv_label text="Filter" align="left_mid" x="10" />
                <lv_label text="Original" align="right_mid" x="-10" style_text_color="0xFF69B4" />
            </lv_button>

            <lv_button width="220" height="44" style_bg_color="0xFFFFFF" style_radius="8" style_border_width="1" style_border_color="0xFF69B4">
                <lv_label text="Photobooth Style" align="left_mid" x="10" />
                <lv_label text="On" align="right_mid" x="-10" style_text_color="0xFF69B4" />
            </lv_button>

            <lv_button width="220" height="44" style_bg_color="0xFFFFFF" style_radius="8" style_border_width="1" style_border_color="0xFF69B4">
                <lv_label text="About" align="left_mid" x="10" />
                <lv_label text="PhotoBooth" align="right_mid" x="-10" style_text_color="0xFF69B4" />
            </lv_button>
        </lv_obj>
    </view>
</screen>